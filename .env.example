# ─────────────────────────────────────────────────────────────────────────────
# AI Newsletter Agent — configuration
# Copy this file to .env and fill in the values for your chosen LLM backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM backend ──────────────────────────────────────────────────────────────
# Choose one: groq | anthropic
LLM_BACKEND=groq

# ── Option A: Groq — FREE tier, no credit card ────────────────────────────
# Sign up at https://console.groq.com  →  API Keys  →  Create key
# Do NOT change GROQ_MODEL — only llama-4-scout supports the tool-calling
# this agent requires. Other Groq models will fail with a 400 error.
GROQ_API_KEY=gsk_...
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct   ← default, do not change

# ── Option B: Anthropic (Claude) — ~$0.05/run ─────────────────────────────
# Sign up at https://console.anthropic.com  (add $5 credit to start)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail delivery ────────────────────────────────────────────────────────────
# Your Gmail address (the account that sends the newsletter)
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password — NOT your regular Gmail password.
# How to get one:
#   1. Enable 2-Step Verification at myaccount.google.com
#   2. Go to Security → App passwords
#   3. Create one named "AI Newsletter" → copy the 16-character code
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to deliver the newsletter (defaults to GMAIL_USER if omitted)
RECIPIENT_EMAIL=your_recipient@gmail.com
