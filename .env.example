# ─────────────────────────────────────────────────────────────────────────────
# AI Newsletter Agent — configuration
# Copy this file to .env and fill in the values that match your chosen backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM backend ──────────────────────────────────────────────────────────────
# Choose one: anthropic | groq | ollama
# Default is 'anthropic' if not set.
LLM_BACKEND=groq

# ── Option A: Anthropic (Claude) — ~$0.01/run ─────────────────────────────
# Sign up at https://console.anthropic.com  (add $5 credit to start)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Option B: Groq — FREE tier, no credit card ────────────────────────────
# Sign up at https://console.groq.com  →  API Keys  →  Create key
# Free tier: 30 req/min, plenty for a weekly newsletter.
GROQ_API_KEY=gsk_...
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct  # default (Llama 4, free, tool-use capable)
# Other options: qwen/qwen3-32b

# ── Option C: Ollama — 100% local, no API key needed ─────────────────────
# Install: https://ollama.com  then run: ollama pull llama3.2
# Start the server once: ollama serve
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── Gmail delivery ────────────────────────────────────────────────────────────
# Your Gmail address (the one that sends the newsletter)
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password — NOT your regular Gmail password.
# How to get one:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App passwords
#   3. Create one named "AI Newsletter" → copy the 16-character code
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to deliver the newsletter (defaults to GMAIL_USER if omitted)
RECIPIENT_EMAIL=nvaikus1109@gmail.com
